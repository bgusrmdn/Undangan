APP_NAME="Undangan Online"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000
APP_DOMAIN=localhost
APP_LOCALE=id
APP_FALLBACK_LOCALE=en

# Domain Configuration
ENABLE_SUBDOMAINS=true
ENABLE_CUSTOM_DOMAINS=true
REQUIRE_DOMAIN_VERIFICATION=true
SUBDOMAIN_PREMIUM_ONLY=false
CUSTOM_DOMAIN_PREMIUM_ONLY=true
MAX_SUBDOMAINS_PER_USER=5

# Database Configuration
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=undangan_online
# DB_USERNAME=root
# DB_PASSWORD=

# Session & Cache
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@undanganonline.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (Optional for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Payment Gateway Configuration
# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# Xendit
XENDIT_SECRET_KEY=
XENDIT_PUBLIC_KEY=

# Social Media Integration (Optional)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# WhatsApp API (Optional)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Google Services (Optional)
GOOGLE_MAPS_API_KEY=
GOOGLE_ANALYTICS_ID=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Application Features
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_CUSTOM_REQUESTS=true
ENABLE_PREMIUM_TEMPLATES=true
ENABLE_GUEST_REGISTRATION=false

# File Upload Limits
MAX_FILE_SIZE=5120  # in KB (5MB)
MAX_GALLERY_IMAGES=10
ALLOWED_IMAGE_TYPES="jpg,jpeg,png,gif,webp"

# Template Settings
FREE_TEMPLATE_LIMIT=3
PREMIUM_TEMPLATE_ACCESS=unlimited

# Custom Request Settings
CUSTOM_REQUEST_MIN_PRICE=100000
CUSTOM_REQUEST_MAX_PRICE=2000000
CUSTOM_REQUEST_DEFAULT_TIMELINE=7  # days

# RSVP Settings
RSVP_DEADLINE_DAYS=7
GUEST_BOOK_ENABLED=true
MAX_RSVP_GUESTS=5

# Analytics
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=365

# Rate Limiting
RATE_LIMIT_API=60  # requests per minute
RATE_LIMIT_WEB=1000  # requests per minute

# Security
FORCE_HTTPS=false
ENABLE_2FA=false
PASSWORD_MIN_LENGTH=8
SESSION_SECURE_COOKIE=false

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Development Tools
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false

# Backup Configuration (Optional)
BACKUP_DISK=local
BACKUP_NOTIFICATION_MAIL=admin@undanganonline.com

# CDN Configuration (Optional)
CDN_URL=
CDN_ENABLED=false

# Redis Configuration (Optional for production)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Image Optimization
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_QUALITY=85
WEBP_CONVERSION=true

# SEO Configuration
SITE_KEYWORDS="undangan online, undangan digital, template undangan, pernikahan, ulang tahun"
SITE_DESCRIPTION="Platform terbaik untuk membuat undangan digital yang elegan dan modern"
SOCIAL_SHARE_IMAGE=images/og-default.jpg

# API Configuration
API_RATE_LIMIT=100
API_VERSION=v1
API_PREFIX=api

# Notification Settings
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="We're currently performing scheduled maintenance. Please check back soon!"

# Performance Settings
ENABLE_QUERY_CACHE=true
CACHE_VIEWS=false
OPTIMIZE_IMAGES=true
COMPRESS_RESPONSES=true

# Development Settings
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"